# Copy to .env and adjust for your deployment. Every variable has a sane
# default in the relay itself; this file documents them and is what
# docker-compose.yml reads by default.

# --- Image: which published tag docker-compose.yml pulls. Defaults to
# `latest`, which tracks the newest commit on main and is not necessarily a
# tagged release; pin a specific release in production. ---
# IMAGE_TAG=v0.1.0

# --- Network ---
PORT=8080
BIND_ADDRESS=0.0.0.0
WS_PATH=/

# --- Slot format (pairing-token-gate proxy for a blind relay) ---
# Accepts the 64-hex pairing slot and the 32-hex ongoing-session slot that
# @kangentic/protocol's deriveSessionSlotId (16 bytes) produces.
SLOT_ID_PATTERN=^([0-9a-f]{32}|[0-9a-f]{64})$

# --- Runaway-bill guards: connection caps ---
MAX_CONNECTIONS=10000
MAX_CONNECTIONS_PER_IP=20
MAX_CONNECTIONS_PER_SLOT=2

# --- Runaway-bill guards: rate limits ---
RATE_LIMIT_IP_PER_MIN=120
RATE_LIMIT_IP_BURST=40
RATE_LIMIT_SLOT_PER_MIN=60
RATE_LIMIT_SLOT_BURST=20

# --- Runaway-bill guards: byte caps ---
# MAX_BUFFERED_BYTES caps how far a slow consumer's outbound socket buffer
# may grow before the tunnel is torn down (close code 4431); it bounds
# worst-case per-connection memory, and both clients reconnect and
# re-handshake by design.
MAX_MESSAGE_BYTES=1114112
MAX_SESSION_BYTES=1073741824
MAX_PARKED_BUFFER_BYTES=1048576
MAX_BUFFERED_BYTES=16777216

# --- Lifecycle ---
PING_INTERVAL_MS=30000
PARK_TIMEOUT_MS=60000
MAX_SESSION_MS=0
SHUTDOWN_GRACE_MS=10000

# --- Real client IP: only enable when a proxy you trust (Cloudflare, Caddy)
# actually fronts this box. TRUSTED_PROXY_CIDRS must name that proxy's
# actual peer address or subnet - the relay refuses to start with
# TRUST_PROXY=true and an empty TRUSTED_PROXY_CIDRS, since that combination
# would trust CF-Connecting-IP / X-Forwarded-For from ANY peer and let a
# client forge either header to bypass every per-IP cap and rate limit
# below. Once a peer is trusted, the relay reads X-Forwarded-For from the
# right (nearest hop first, skipping trusted-proxy hops), not the left, so
# a proxy that appends to the header rather than replacing it is still
# safe. See README.md's "Deploying for real" section. ---
TRUST_PROXY=false
TRUSTED_PROXY_CIDRS=
IPV6_PREFIX_BITS=64

# --- Metrics ---
METRICS_ENABLED=true
METRICS_TOKEN=

# --- Logging: slot ids are hashed by default; the pairing graph (which
# slot ids co-occur) is sensitive metadata even though payloads never are.
# SLOT_LOG_SALT defaults to a random value generated fresh on every
# process start, which means hashed slot ids stop correlating across a
# restart. Pin an explicit value in production if you need that
# correlation to survive restarts, and treat it as a secret. ---
LOG_LEVEL=info
LOG_SLOT_HASHING=true
SLOT_LOG_SALT=

# --- Admission (open-core seam): unset means every connection is admitted.
# A private control plane sets this to its own HTTPS endpoint; the relay
# itself never links or imports that plane in-process (see README/AGPL) ---
ADMISSION_WEBHOOK_URL=
ADMISSION_WEBHOOK_TIMEOUT_MS=3000
ADMISSION_FAIL_OPEN=true
